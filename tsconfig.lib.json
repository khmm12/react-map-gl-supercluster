{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM"],
    "module": "NodeNext",
    "outDir": "./node_modules/.tmp/lib",
    "rootDir": "./src",
    "target": "ESNext"
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
