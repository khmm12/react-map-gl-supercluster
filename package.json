    "startCommand": "pnpm example"
  },
  "scripts": {
    "build": "tsdown",
    "example": "vite example",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "lint": "biome check",
    "test": "vitest run --coverage",
    "typecheck": "tsc -b --pretty --force",
    "bench": "vitest bench --run"
  },
  "dependencies": {
    "@types/supercluster": "^7.1.3",
    "esm-env": "^1.2.2",
    "supercluster": "^8.0.1"
