  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "mapbox-gl": {
      "optional": true
    },
    "maplibre-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@biomejs/biome": "^2.5.3",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@tsconfig/vite-react": "^8.1.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "happy-dom": "^20.10.6",
    "mapbox-gl": "^3.26.0",
    "maplibre-gl": "^5.24.0",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-map-gl": "^8.1.1",
    "tsdown": "^0.22.7",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
