  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khmm12/react-map-gl-supercluster.git"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    "./mapbox": {
      "types": "./dist/exports-mapbox.d.ts",
      "import": "./dist/exports-mapbox.js"
    },
    "./maplibre": {
      "types": "./dist/exports-maplibre.d.ts",
      "import": "./dist/exports-maplibre.js"
    },
    "./mapbox-legacy": {
      "types": "./dist/exports-mapbox-legacy.d.ts",
      "import": "./dist/exports-mapbox-legacy.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react-map-gl",
    "supercluster",
    "clustering",
    "react"
  ],
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
